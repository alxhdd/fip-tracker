# ---- Copy to .env and fill in. ----

# Public base URL of your deployment (used for OAuth redirects and cookie security).
# Use https://your-domain in production so session cookies are marked Secure.
BASE_URL=http://localhost:3000
PORT=3000

# Where the SQLite database + session secret live. Back this folder up.
DATA_DIR=./data

# Optional: pin a session secret (otherwise one is generated in DATA_DIR).
# SESSION_SECRET=change-me-to-a-long-random-string

# ---- Google OAuth ----
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <BASE_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Facebook Login (optional) ----
# https://developers.facebook.com/apps → Facebook Login → Settings
# Valid OAuth Redirect URI: <BASE_URL>/auth/facebook/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ---- Local testing only ----
# Set to 1 to enable a passwordless "dev user" login while OAuth isn't set up yet.
# Leave unset/0 in production.
ALLOW_DEV_LOGIN=1
